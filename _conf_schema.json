{
	"locale": {
		"description": "语言",
		"type": "string",
		"default": "zh_CN",
		"options": ["zh_CN", "en_US"],
		"labels": ["简体中文", "English"],
		"hint": "选择插件显示语言"
	},
	"default_mute_duration": {
		"description": "默认禁言时长（秒）",
		"type": "int",
		"default": 60,
		"hint": "未指定时长时的默认禁言秒数"
	},
	"default_welcome_enabled": {
		"description": "新人欢迎默认开启",
		"type": "bool",
		"default": true,
		"hint": "新群是否默认开启欢迎消息"
	},
	"default_welcome_message": {
		"description": "默认欢迎消息",
		"type": "text",
